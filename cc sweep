function playAlertAnimation() {
  const img = document.getElementById('alert-img');
  let currentFrame = 0;
  
  const interval = setInterval(() => {
    img.src = FRAMES[currentFrame++];
    if (currentFrame >= FRAMES.length) {
      clearInterval(interval);
    }
  }, 1000 / 30);
}
